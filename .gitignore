# Obsidian — exclude plugin binaries and themes (large, reinstallable)
# but keep core config files (app.json, community-plugins.json, etc.)
**/.obsidian/plugins/
**/.obsidian/themes/
**/.obsidian/workspace.json

# Prevent accidentally opening the repo root as an Obsidian vault —
# the real vault lives at Obsidian/Working Title/. A root-level
# .obsidian/ means someone opened the wrong folder.
/.obsidian/

# Obsidian cache
**/.keep-the-rhythm/

# Media & attachments — backed up via Google Drive instead
attachments/
_media/
*.png
*.jpg
*.jpeg
*.gif
*.pdf
*.mp3
*.mp4
*.mov

# Claude Code local state
.claude/

# macOS system files
.DS_Store
**/.DS_Store
