# Obsidian — exclude plugin binaries and themes (large, reinstallable)
# but keep core config files (app.json, community-plugins.json, etc.)
**/.obsidian/plugins/
**/.obsidian/themes/
**/.obsidian/workspace.json

# The vault lives at Obsidian/Working Title/, not the repo root.
# Ignore any Obsidian config that lands at the root.
/.obsidian/

# Obsidian cache
**/.keep-the-rhythm/

# Media & attachments — backed up via Google Drive instead
attachments/
_media/
*.png
*.jpg
*.jpeg
*.gif
*.pdf
*.mp3
*.mp4
*.mov

# Claude Code local state
.claude/

# JetBrains IDE config
/.idea/

# macOS system files
.DS_Store
**/.DS_Store
